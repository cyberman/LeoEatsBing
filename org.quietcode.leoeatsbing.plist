<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple Computer//DTD PLIST 1.0//EN"
 "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

    <key>Label</key>
    <string>org.quietcode.leoeatsbing</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/admin/LeoEatsBing/leoeatsbing.sh</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>6</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/admin/Library/Logs/LeoEatsBing.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/admin/Library/Logs/LeoEatsBing.error.log</string>

</dict>
</plist>

